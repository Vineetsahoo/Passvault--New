# ── Supabase ─────────────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard.
SUPABASE_URL=https://your-project-ref.supabase.co
# The SERVICE ROLE key, not the anon key — this bypasses RLS, so it only
# ever belongs here (server-side) and in your Railway env vars. Never send
# it to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# AES-256-GCM key used to encrypt vault passwords + document encryption
# keys (lib/cryptoUtils.js). Any 32-character string, or longer — it gets
# SHA-256-hashed down to 32 bytes either way. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-character-encryption-key

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ── Remove once every route file is migrated off Mongoose ──────────────────
# server.js keeps both databases wired up during the transition (see the
# comment above connectMongo() in server.js). Once routes/devices.js,
# qrcodes.js, alerts.js, sync.js, backups.js, storage.js, history.js,
# monitoring.js, transactions.js, sharing.js, terminalQr.js, and user.js are
# all converted, delete this whole section plus the mongoose import and
# connectMongo() call in server.js.
MONGODB_URI=mongodb://localhost:27017/passvault
DB_NAME=passvault
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_REFRESH_EXPIRE=7d
BCRYPT_SALT_ROUNDS=12
