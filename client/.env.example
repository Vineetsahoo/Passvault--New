# ── Supabase ─────────────────────────────────────────────────────────────
# Same project as server/.env, but the ANON (public) key here, not the
# service role key — this one is safe to ship to the browser. RLS is what
# keeps it safe: it can only do what the policies in the schema allow for
# the signed-in user.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── App ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_NODE_ENV=development
VITE_DEBUG=false
